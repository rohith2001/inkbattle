# Copy this file to .env and fill in values. Do NOT commit .env (it is in .gitignore).
# Real / staging values stay in .env only; the repo only has this example with no secrets.

# --- API CONFIGURATION ---
API_BASE_URL=
SOCKET_URL=

# --- OPTIONAL (app has safe defaults if missing) ---
AGORA_APP_ID=
GOOGLE_WEB_CLIENT_ID=

# Examples:
# Staging:  API_BASE_URL=https://staging.inkbattle.in/api  SOCKET_URL=https://staging.inkbattle.in
# Local:    API_BASE_URL=http://localhost:4000/api         SOCKET_URL=http://localhost:4000
# Same LAN: API_BASE_URL=http://192.168.x.x:4000/api       SOCKET_URL=http://192.168.x.x:4000
